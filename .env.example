# PostgreSQL
POSTGRES_USER=kundli
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kundli_db

# Django
DJANGO_SECRET_KEY=changeme-generate-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_ORIGIN=http://localhost:5173

# Redis (no auth in dev; set password for prod)
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=kundli-media
AWS_S3_USE_SSL=False
AWS_S3_ADDRESSING_STYLE=path

# Ollama (running locally on host)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llava:7b

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
